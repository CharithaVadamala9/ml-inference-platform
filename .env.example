# Copy to .env and fill in. Never commit .env.
# ---- LLM judge / generation provider ----
# Used by the LLM-as-a-judge and (optionally) the RAG generator.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Which provider the eval judge uses: "openai" | "anthropic"
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o-mini

# ---- Serving backend ----
# Which engine the FastAPI gateway serves from: "ollama" | "vllm" | "openai"
SERVING_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL=

# ---- MLflow ----
MLFLOW_TRACKING_URI=http://localhost:5000
